# Kopieer naar .env.local en vul aan (zie https://resend.com/api-keys)
RESEND_API_KEY=

# Inbox waar contact- en offerte-mails binnenkomen
RESEND_TO_EMAIL=info@meubelstoffeerderijnoordwijk.nl

# Afzender: adres op je geverifieerde Resend-domein (noordwijkmeubelstoffeerderij.nl).
# Standaard in code: noreply@noordwijkmeubelstoffeerderij.nl — overschrijf alleen als je een ander alias gebruikt.
# RESEND_FROM_EMAIL=Meubelstoffeerderij Noordwijk <website@noordwijkmeubelstoffeerderij.nl>
